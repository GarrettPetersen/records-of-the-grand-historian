    "url": "https://chinesenotes.com/beiqishu/beiqishu005.html",
    "title": {
      "zh": "卷五 補帝紀第五 廢帝",
      "en": "Volume 5 Annals 5: Emperor Fei",
      "raw": "卷五 補帝紀第五 廢帝 Volume 5 Annals 5: Emperor Fei"
    },
    "sentenceCount": 43,
    "translatedCount": 0,
    "glossarySize": 39672,
    "scrapedAt": "2026-04-25T21:53:06.126Z",
