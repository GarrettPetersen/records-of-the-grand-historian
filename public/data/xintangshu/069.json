        {
          "id": "s0013",
          "zh": "764 二年 置湖南都團練守捉觀察處置使，治衡州，領衡、潭、邵、永、道五州，治衡州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0014",
          "zh": "廢邕州管內都防禦使，以所管州隸桂管經略使。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0015",
          "zh": "置桂邕都防禦、觀察、招討、處置等使，增領邕管諸州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0016",
          "zh": "改安南節度使為鎮南大都護、都防禦、觀察、經略使。",
