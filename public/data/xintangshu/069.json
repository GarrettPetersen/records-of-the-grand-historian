    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0006",
          "zh": "755 十四載 五溪經略使增領守捉使。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0007",
          "zh": "置邕州管內經略使，領邕、貴、橫、欽、澄、賓、嚴、羅、淳、瀼、山、田、籠十三州，治邕州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0008",
          "zh": "置容州管內經略使，領容、白、禺、牢、繡、黨、竇、廉、義、鬱林、湯、巖、辯、平琴十四州，治容州。",
          "translations": [
            {
              "lang": "en",
