              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0014",
          "zh": "置魏博等州防禦使，領魏、博、貝、瀛、滄五州，治魏州。",
          "translations": [
