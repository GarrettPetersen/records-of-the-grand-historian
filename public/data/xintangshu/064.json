    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0015",
          "zh": "763 廣德元年 罷鎮國軍節度。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0016",
          "zh": "懷州隸昭義，陝西觀察使增領虢州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
