    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0040",
          "zh": "785 貞元元年 永平軍節度更號義成軍節度，增領許州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0041",
          "zh": "唐州隸東都畿，許州隸義成軍節度。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
