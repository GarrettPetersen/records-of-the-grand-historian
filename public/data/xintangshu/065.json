    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0045",
          "zh": "821 長慶元年 宿州隸淮南節度。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0046",
          "zh": "升沂海觀察使為節度使，徙治兗州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0047",
          "zh": "河東節度使領押北山諸蕃使。",
          "translations": [
