    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0035",
          "zh": "776 十一年 永平節度增領宋、泗二州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0036",
          "zh": "廢河南節度使，曹、兗、鄆、濮、徐五州隸淄青節度，宋、潁、泗三州隸永平軍節度，汴州隸淮西節度。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0037",
          "zh": "淮西節度使增領汴州，徙治汴州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0038",
          "zh": "淄青平盧節度增領鄆、曹、濮、徐、兗五州，以泗州隸永平軍節度。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
