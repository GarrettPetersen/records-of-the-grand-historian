    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0118",
          "zh": "周制：封郡縣五等爵者，皆加開國；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0119",
          "zh": "授柱國大將軍、開府、儀同者，並加使持節、大都督；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0120",
          "zh": "其開府又加〔驃騎大將軍、侍中；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0121",
          "zh": "其儀同又加〕車騎大將軍、散騎常侍；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0122",
          "zh": "其授總管刺史，則加使持節、諸軍事。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0123",
          "zh": "以此為常。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0124",
          "zh": "大象元年，詔總管刺史及行兵者，加持節，餘悉罷之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
