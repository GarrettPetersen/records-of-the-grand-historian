  "content": [
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0001",
          "zh": "南齊書卷五十‧列傳第三十一",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0002",
          "zh": "文二王 明七王",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0003",
          "zh": "文惠太子四男：安皇后生鬱林王昭業；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0004",
          "zh": "宮人許氏生海陵恭王昭文；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0005",
          "zh": "陳氏生巴陵王昭秀；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0006",
          "zh": "褚氏生桂陽王昭粲。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0007",
          "zh": "明帝十一男：敬皇后生東昏侯寶卷，江夏王寶玄，鄱陽王寶寅，和帝；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0008",
          "zh": "殷貴嬪生巴陵隱王寶義，晉熙王寶嵩；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0009",
          "zh": "袁貴妃生廬陵王寶源；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0010",
          "zh": "管淑妃生邵陵王寶攸；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0011",
          "zh": "許淑媛生桂陽王寶貞。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0012",
          "zh": "餘皆早夭。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0013",
          "zh": "巴陵隱王寶義字智勇，明帝長子也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0014",
          "zh": "本名明基。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0015",
          "zh": "建武元年，爲持節、都督揚南徐州軍事、前將軍、揚州刺史。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0016",
          "zh": "封晉安郡王，三千戶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0017",
          "zh": "寶義少有廢疾，不堪出人閒，故止加除授，仍以始安王遙光代之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0018",
          "zh": "轉寶義爲右將軍，領兵置佐，鎮石頭。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0019",
          "zh": "二年，出爲使持節、都督南徐州軍事、鎮北將軍、南徐州刺史。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0020",
          "zh": "東昏卽位，進征北大將軍，開府儀同三司，給扶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0021",
          "zh": "永元元年，給班劔二十人。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0022",
          "zh": "始安王遙光誅，爲都督揚南徐二州軍事、驃騎大將軍、揚州刺史，持節如故。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0023",
          "zh": "東府被兵火，屋宇燒殘，帝方營宮殿，不暇脩葺，寶義鎮西州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0024",
          "zh": "三年，進位司徒。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0025",
          "zh": "和帝西臺建，以爲侍中、司空，使持節、都督、刺史如故。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0026",
          "zh": "梁王定京邑，宣德太后令以寶義爲太尉，領司徒。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0027",
          "zh": "詔云：「不言之化，形于自遠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0028",
          "zh": "」時人皆云此實錄也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0029",
          "zh": "梁受禪，封謝沐縣公，尋封巴陵郡王，奉齊後。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0030",
          "zh": "天監中薨。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0031",
          "zh": "寶玄娶尚書令徐孝嗣女爲妃，孝嗣被誅離絕，少帝送少姬二人與之，寶玄恨望，密有異計。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0032",
          "zh": "明年，崔慧景舉兵，還至廣陵，遣使奉寶玄爲主。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0033",
          "zh": "寶玄斬其使，因是發將吏防城。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0034",
          "zh": "帝遣馬軍主戚平、外監黃林夫助鎮京口。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0035",
          "zh": "慧景將渡江，寶玄密與相應，殺司馬孔矜、典籤呂承緒及平、林夫，開門納慧景。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0036",
          "zh": "使長史沈佚之、諮議柳憕分部軍衆，乘八掆輿，手執絳麾幡，隨慧景至京師，住東城，百姓多往投集。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0037",
          "zh": "慧景敗，收得朝野投寶玄及慧景軍名，帝令燒之，曰：「江夏尚爾，豈復可罪餘人。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0038",
          "zh": "」寶玄逃奔數日乃出。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0039",
          "zh": "帝召入後堂，以步鄣裹之，令羣小數十人鳴鼓角馳繞其外，遣人謂寶玄曰：「汝近圍我亦如此。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0040",
          "zh": "」少日乃殺之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0041",
          "zh": "廬陵王寶源字智淵，明帝第五子也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0042",
          "zh": "建武元年，爲北中郎將，鎮琅邪城，封廬陵郡王。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0043",
          "zh": "遷右將軍，領石頭戍事，仍出爲使持節、都督南兖兖徐青冀五州軍事、後將軍、南兖州刺史。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0044",
          "zh": "王敬則伏誅，徙寶源爲都督會稽東陽臨海永嘉新安五郡軍事、會稽太守，將軍如故。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0045",
          "zh": "永元元年，進號安東將軍。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0046",
          "zh": "和帝卽位，以爲侍中、車騎將軍、開府儀同三司，都督、太守如故。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0047",
          "zh": "未拜，中興二年薨。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0048",
          "zh": "鄱陽王寶夤字智亮，明帝第六子也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0049",
          "zh": "建武初，封建安郡王。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0050",
          "zh": "二年，爲北中郎將，鎮琅邪城。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0051",
          "zh": "明年，出爲持節、都督江州軍事、南中郎將、江州刺史。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0052",
          "zh": "東昏卽位，爲使持節、都督郢司二州軍事、征虜將軍、郢州刺史。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0053",
          "zh": "尋進號前將軍。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0054",
          "zh": "永元二年，徵爲撫軍，領石頭戍事，未拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0055",
          "zh": "三年，爲車騎將軍、開府儀同三司，鎮石頭。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0056",
          "zh": "其秋，雍州刺史張欣泰等謀起事於新亭，殺臺內諸主帥，事在欣泰傳。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0057",
          "zh": "難作之日，前南譙太守王靈秀奔往石頭，率城內將吏見力，去車脚載寶夤向臺城，百姓數千人皆空手隨後，京邑騷亂。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0058",
          "zh": "寶夤至杜姥宅，日已欲暗，城門閉，城上人射之，衆棄寶夤逃走。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0059",
          "zh": "寶夤逃亡三日，戎服詣草市尉，尉馳以啓帝，帝迎寶寅入宮問之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0060",
          "zh": "寶夤涕泣稱：「爾日不知何人逼使上車，仍將去，制不自由。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0061",
          "zh": "」帝笑，乃復爵位。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0062",
          "zh": "和帝立，西臺以寶夤爲使持節、都督南徐兖二州軍事、衞將軍、南徐州刺史。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0063",
          "zh": "少帝以爲使持節、都督荊益寧雍梁南北秦七州軍事、荊州刺史，將軍如故。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0064",
          "zh": "宣德太后臨朝，梁王爲建安公，改封寶夤爲鄱陽王。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0065",
          "zh": "中興二年，謀反誅。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0066",
          "zh": "桂陽王寶貞，明帝第十一子也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0067",
          "zh": "永元二年，爲中護軍、北中郎將，領石頭戍事。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0068",
          "zh": "中興二年，謀反伏誅。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0069",
          "zh": "史臣曰：《春秋》書「鄭伯克段于鄢」，兄弟之恩離，君臣之義正。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0070",
          "zh": "夫逆從有勢，況親兼一體，道窮數盡，或容觸啄。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0071",
          "zh": "而寶玄自尋干戈，欣受家難。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0072",
          "zh": "曾不悟執柯所指，跗蕚相從，以此而圖萬全，未知其髣髴也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0073",
          "zh": "贊曰：文惠二王，于嗟夭殤。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0074",
          "zh": "明子七國，終亦衰亡。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0075",
          "zh": "[1]",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
