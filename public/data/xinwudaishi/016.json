      "type": "paragraph",
      "sentences": [
        {
          "id": "s0001",
          "zh": "廢帝皇后劉氏",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
