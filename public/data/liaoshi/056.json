  "content": [
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0001",
          "zh": "儀衛誌二 ○國服",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0002",
          "zh": "上古之人，網罟禽獸，食肉衣皮，以儷鹿韋掩前後，謂之鞸。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0003",
          "zh": "然後夏葛冬裘之制興焉。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0004",
          "zh": "周公陳王業，《七月》之詩，至於一日於貉，三月條桑，八月載績，公私之用由是出矣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0005",
          "zh": "契丹轉居薦草之間，去邃古之風猶未遠也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0006",
          "zh": "太祖仲父述瀾，以遙輦氏於越之官，占居潢河沃壤，始置城邑，為樹藝、桑麻、組織之教，有遼王業之隆，其亦肇跡於此乎！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0007",
          "zh": "太祖帝北方，太宗制中國，紫銀之鼠，羅綺之篚，麇載而至。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0008",
          "zh": "纖麗耎毳，被土綢木。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0009",
          "zh": "於是定衣冠之制，北班國制，南班漢制，各從其便焉。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0010",
          "zh": "詳國服以著厥始雲。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0011",
          "zh": "祭服：遼國以祭山為大禮，服飾尤盛。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0012",
          "zh": "大祀，皇帝服金文金冠，白綾袍，紅帶，懸魚，三山紅垂。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0013",
          "zh": "飾犀玉刀錯，絡縫烏靴。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0014",
          "zh": "小祀，皇帝硬帽，紅克絲龜文袍。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0015",
          "zh": "皇后戴紅帕，服絡縫紅袍，懸玉佩，雙同心帕，絡縫烏靴。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0016",
          "zh": "臣僚、命婦服飾，各從本部旗幟之色。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0017",
          "zh": "朝服：太祖丙寅歲即皇帝位，朝服衷甲，以備非常。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0018",
          "zh": "其後行瑟瑟禮、大射柳，即此服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0019",
          "zh": "聖宗統和元年冊承天皇太后，給三品以上用漢法服，三品以下用大射柳之服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0020",
          "zh": "皇帝服實裏薛袞冠，絡縫紅袍，垂飾犀玉帶錯，絡縫靴，謂之國服袞冕。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0021",
          "zh": "太宗更以錦袍、金帶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0022",
          "zh": "臣僚戴氈冠，金花為飾，或加珠玉翠毛，額後垂金花，織成夾帶，中貯發一總。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0023",
          "zh": "或紗冠，制如烏紗帽，無檐，不擫雙耳。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0024",
          "zh": "額前綴金花，上結紫帶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0025",
          "zh": "末綴珠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0026",
          "zh": "服紫窄袍、系䩞鞢帶，以黃紅色絳裹革為之，用金玉、水晶、靛石綴飾，謂之「盤紫」。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0027",
          "zh": "太宗更以錦袍、金帶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0028",
          "zh": "會同元年，群臣高年有爵秩者，皆賜之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0029",
          "zh": "公服：謂之「展裹」，著紫。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0030",
          "zh": "興宗重熙二十二年，詔八房族巾幘。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0031",
          "zh": "道宗清寧元年，詔非勛戚之後及夷離堇副使並承應有職事人，不帶巾。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0032",
          "zh": "皇帝紫皂幅巾，紫窄袍，玉束帶，或衣紅襖；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0033",
          "zh": "臣僚亦幅巾，紫衣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0034",
          "zh": "常服：",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0035",
          "zh": "《宰相中謝儀》，帝常服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0036",
          "zh": "《高麗使入見儀》，臣僚便衣，謂之「盤裹」。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0037",
          "zh": "綠花窄袍，中單多紅綠色。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0038",
          "zh": "貴者披貂裘，以紫黑色為貴，青次之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0039",
          "zh": "又有銀鼠，尤潔白。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0040",
          "zh": "賤者貂毛、羊、鼠、沙狐裘。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0041",
          "zh": "田獵服：",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0042",
          "zh": "皇帝幅巾，擐甲戎裝，以貂鼠或鵝項、鴨頭為扞腰。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0043",
          "zh": "蕃漢諸司使以上並戎裝，衣皆左衽，黑綠色。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0044",
          "zh": "吊服：太祖叛弟剌哥等降，素服受之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0045",
          "zh": "素服，乘赭白馬。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0046",
          "zh": "祭服：終遼之世，郊丘不建，大裘冕服不書。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0047",
          "zh": "袞冕，祭祀宗廟、遣上將出征、飲至、踐阼、加元服、納後若元日受朝則服之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0048",
          "zh": "金飾，垂白珠十二旒，以組為纓，色如其綬，黈纊充耳，玉簪導。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0049",
          "zh": "玄衣、纁裳十二章：八章在衣，日、月、星、龍、華蟲、火、山、宗彜；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0050",
          "zh": "四章在裳，藻、粉米、黼、黻。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0051",
          "zh": "衣褾領，為升龍織成文，各為六等。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0052",
          "zh": "龍山以下，每章一行，行十二，白紗中單，黼領，青褾襈裾，黼革帶、大帶，劍佩綬，舄加金飾。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0053",
          "zh": "《元日朝會儀》，皇帝服袞冕。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0054",
          "zh": "朝服：乾亨五年，聖宗冊承天太后，給三品以上法服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0055",
          "zh": "《雜禮》，冊承天太后儀，侍中就席解劍脫履。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0056",
          "zh": "重熙五年尊號冊禮，皇帝服龍袞，北南臣僚並朝服，蓋遼制。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0057",
          "zh": "會同中，太后、北面臣僚國服；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0058",
          "zh": "皇帝、南面臣僚漢服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0059",
          "zh": "乾亨以後，大禮雖北面三品以上亦用漢服；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0060",
          "zh": "重熙以後，大禮並漢服矣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0061",
          "zh": "常朝仍遵會同之制。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0062",
          "zh": "皇帝通天冠，諸祭還及冬至、朔日受朝、臨軒拜王公、元會、冬會服之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0063",
          "zh": "冠加金博山，附蟬十二，首施珠翠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0064",
          "zh": "黑介幘，緌纓翠緌，玉若犀簪導。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0065",
          "zh": "絳紗袍，白紗中單，褾領，朱襈裾，白裙襦，絳蔽膝，白假帶方心曲領。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0066",
          "zh": "其革帶佩劍綬，襪舄。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0067",
          "zh": "若未加元服，則雙童髻，空頂，黑介幘，雙玉導，加寶飾。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0068",
          "zh": "《元日上壽儀》，皇帝服通天冠，絳紗袍。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0069",
          "zh": "皇太子遠遊冠，謁廟還宮、元日、冬至朔日入朝服之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0070",
          "zh": "三梁冠，加金附蟬九，首施珠翠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0071",
          "zh": "黑介幘，發纓翠緌，犀簪導。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0072",
          "zh": "絳紗袍，白紗中單，皂領褾，襈裾，白裾襦，白假帶方心曲領，絳紗蔽膝。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0073",
          "zh": "其革帶劍佩綬，襪舄與上同，後改用白襪、黑舄。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0074",
          "zh": "未冠，則雙童髻，空頂，黑介幘，雙玉導，加寶飾。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0075",
          "zh": "《冊皇太子儀》，皇太子冠遠遊，服絳紗袍。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0076",
          "zh": "親王遠遊冠，陪祭朝饗、拜表、大事服之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0077",
          "zh": "冠三梁，加金附蟬。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0078",
          "zh": "黑介幘，青緌導。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0079",
          "zh": "絳紗單衣，白紗中單，皂領，襈裾，白裾襦。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0080",
          "zh": "革帶鈎䚢，假帶曲領方心，絳紗蔽膝，襪舄，劍佩綬二品以上同。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0081",
          "zh": "諸王遠遊冠，三梁，黑介幘，青緌。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0082",
          "zh": "三品以上進賢冠，三梁，寶飾。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0083",
          "zh": "五品以上進賢冠，二梁，金飾。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0084",
          "zh": "九品以上進賢冠，一梁，無飾。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0085",
          "zh": "七品以上去劍佩綬。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0086",
          "zh": "八品以下同公服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0087",
          "zh": "公服：《勘箭儀》，閣使公服，系履。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0088",
          "zh": "遼國常用公服矣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0089",
          "zh": "皇帝翼善冠，朔視朝用之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0090",
          "zh": "柘黃袍，九環帶，白練裙襦，六合靴。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0091",
          "zh": "皇太子遠遊冠，五日常朝、元日、冬至受朝服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0092",
          "zh": "絳紗單衣，白裙襦，革帶，金鈎䚢，假帶方心，紛鞶囊，白䚢，烏皮履。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0093",
          "zh": "一品以下、五品以上。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0094",
          "zh": "冠幘纓，簪導，謁見東宮及餘公事服之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0095",
          "zh": "絳紗單衣，白裙襦，帶鈎䚢，假帶方心，襪履，紛鞶囊。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0096",
          "zh": "六品以下，冠幘纓，簪導，去紛鞶囊，餘並同。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0097",
          "zh": "常服：遼國謂之「穿執」。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0098",
          "zh": "起居禮臣僚穿執。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0099",
          "zh": "言穿靴、執笏也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0100",
          "zh": "皇帝柘黃袍衫，折上頭巾，九環帶，六合靴，起自宇文氏。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0101",
          "zh": "唐太宗貞觀已後，非元日、冬至受朝及大祭祀，皆常服而已。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0102",
          "zh": "皇太子進德冠，九琪，金飾，絳紗單衣，白裙襦，白襪，烏皮履。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0103",
          "zh": "五品以上，襆頭，亦曰折上巾，紫袍，牙笏，金玉帶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0104",
          "zh": "文官佩手巾、算袋、刀子、礪石、金魚袋；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0105",
          "zh": "武官䩞鞢七事：佩刀、刀子、磨石、契真、噦厥、針筒、火石袋。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0106",
          "zh": "烏皮六合靴。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0107",
          "zh": "六品以下，襆頭，緋衣，木笏，銀帶，銀魚袋佩，靴同。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0108",
          "zh": "八品九品，襆頭，綠袍，鍮石帶，靴同。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    }
  ]
}