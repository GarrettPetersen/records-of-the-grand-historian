    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0033",
          "zh": "十二宮一府，自上京至南京總要之地，各置提轄司，重地每宮皆置，內地一二而已。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0034",
          "zh": "太和、永昌二宮宜與興聖、延慶同，舊史不見提轄司，蓋闕文也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
