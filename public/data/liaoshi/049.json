  "content": [
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0001",
          "zh": "禮志一",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0002",
          "zh": "理自天設，情由人生。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0003",
          "zh": "以理制情，而禮樂之用行焉。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0004",
          "zh": "林豺梁獺，是生郊禘；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0005",
          "zh": "窪尊燔黍，是生燕饗；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0006",
          "zh": "虆梩瓦棺，是生喪葬；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0007",
          "zh": "儷皮緇布，是生婚冠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0008",
          "zh": "皇造帝秩，三王彌文。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0009",
          "zh": "一文一質，蓋本於忠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0010",
          "zh": "變通革弊，與時宜之，唯聖人為能通其意。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0011",
          "zh": "執理者膠瑟聚訟，不適人情；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0012",
          "zh": "徇情者梯稗綿蕝，不中天理。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0013",
          "zh": "秦漢而降，君子無取焉。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0014",
          "zh": "遼本朝鮮故壤，箕子八條之教，流風遺俗，蓋有存者。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0015",
          "zh": "自其上世，緣情制宜，隱然有尚質之風。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0016",
          "zh": "遙輦胡剌可汗制祭山儀，蘇可汗制瑟瑟儀，阻午可汗制柴冊、再生儀。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0017",
          "zh": "其情樸，其用儉。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0018",
          "zh": "敬天恤災，施惠本孝，出於悃忱，殆有得於膠瑟聚訟之表者。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0019",
          "zh": "太古之上，椎輪五禮，何以異茲。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0020",
          "zh": "太宗克晉，稍用漢禮。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0021",
          "zh": "今國史院有金陳大任《遼禮儀志》，皆其國俗之故，又有《遼朝雜禮》，漢儀為多。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0022",
          "zh": "別得宣文閣所藏耶律儼《志》，視大任為加詳。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0023",
          "zh": "存其略，著於篇。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0024",
          "zh": "祭山儀：設天神、地祇位於木葉山，東向；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0025",
          "zh": "中立君樹，前植群樹，以像朝班；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0026",
          "zh": "又偶植二樹，以為神門。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0027",
          "zh": "皇帝、皇后至，夷離畢具禮儀。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0028",
          "zh": "牲用赭白馬、玄牛、赤白羊，皆牡。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0029",
          "zh": "仆臣曰旗鼓拽剌，殺牲，體割，懸之君樹。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0030",
          "zh": "太巫以酒酹牲。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0031",
          "zh": "禮官曰敵烈麻都，奏「儀辦」。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0032",
          "zh": "皇帝服金文金冠，白綾袍，絳帶，懸魚，三山絳垂，飾犀玉刀錯，絡縫烏靴。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0033",
          "zh": "皇后禦絳末，絡縫紅袍，懸玉佩，雙結帕，絡縫烏靴。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0034",
          "zh": "皇帝、皇后禦鞍馬。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0035",
          "zh": "群臣在南，命婦在北，服從各部旗幟之色以從。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0036",
          "zh": "皇帝、皇后至君樹前下馬，升南壇禦榻坐。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0037",
          "zh": "群臣命婦分班，以次入就位；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0038",
          "zh": "合班，拜訖，復位。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0039",
          "zh": "皇帝皇后詣天神、地祇位，致奠；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0040",
          "zh": "閣門使讀祝訖，復位坐。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0041",
          "zh": "北府宰相及惕隱以次致奠於君樹，遍及群樹。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0042",
          "zh": "樂作。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0043",
          "zh": "群臣、命婦退。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0044",
          "zh": "皇帝率孟父、仲父、季父之族，三匝神門樹；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0045",
          "zh": "餘族七匝。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0046",
          "zh": "皇帝、皇后再拜，在位者皆再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0047",
          "zh": "上香，再拜如初。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0048",
          "zh": "皇帝、皇后升壇，禦龍文方茵坐。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0049",
          "zh": "再聲警，詣祭東所，群臣、命婦從，班列如初。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0050",
          "zh": "巫衣白衣，惕隱以素巾拜而冠之，巫三致辭。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0051",
          "zh": "每致辭，皇帝、皇后一拜，在位者皆一拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0052",
          "zh": "皇帝、皇后各舉酒二爵，肉二器，再奠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0053",
          "zh": "大臣、命婦右持酒，左持肉各一器，少後立，一奠。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0054",
          "zh": "命惕隱東向擲之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0055",
          "zh": "皇帝、皇后六拜，在位者皆六拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0056",
          "zh": "皇帝、皇后復位，坐。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0057",
          "zh": "命中丞奉茶果、餅餌各二器奠於天神、地祇位。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0058",
          "zh": "執事郎君二十人持福酒、胙肉，詣皇帝、皇后前。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0059",
          "zh": "太巫奠酹訖，皇帝、皇后再拜，在位者皆再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0060",
          "zh": "皇帝、皇后一拜，飲福，受胙，復位，坐。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0061",
          "zh": "在位者以次飲。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0062",
          "zh": "皇帝、皇后率群臣復班位，再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0063",
          "zh": "聲蹕，一拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0064",
          "zh": "退。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0065",
          "zh": "太宗幸幽州大悲閣，遷白衣觀音像，建廟木葉山，尊為家神。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0066",
          "zh": "於拜山儀過樹之後，增詣菩薩堂儀一節，然後拜神，非胡剌可汗之故也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0067",
          "zh": "興宗先有事於菩薩堂及木葉山遼河神，然後行拜山儀，冠服、節文多所變更，後因以為常。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0068",
          "zh": "神主樹木，懸牲告辦，班位奠祝，致嘏飲福，往往暗合於禮。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0069",
          "zh": "天理人情，放諸四海而準，信矣夫。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0070",
          "zh": "興宗更制，不能正以經術，無以大過於昔，故不載。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0071",
          "zh": "瑟瑟儀：若旱，擇吉日行瑟瑟儀以祈雨。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0072",
          "zh": "前期，置百柱天棚。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0073",
          "zh": "及期，皇帝致奠於先帝御容，乃射柳。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0074",
          "zh": "皇帝再射，親王、宰執以次各一射。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0075",
          "zh": "中柳者質誌柳者冠服，不中者以冠服質之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0076",
          "zh": "不勝者進飲於勝者，然後各歸其冠服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0077",
          "zh": "又翼日，植柳天棚之東南，巫以酒醴、黍稗薦植柳，祝之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0078",
          "zh": "皇帝、皇后祭東方畢，子弟射柳。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0079",
          "zh": "皇族、國舅、群臣與禮者，賜物有差。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0080",
          "zh": "既三日雨，則賜敵烈麻都馬四匹、衣四襲；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0081",
          "zh": "否則以水沃之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0082",
          "zh": "道宗清寧元年，皇帝射柳訖，詣風師壇，再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0083",
          "zh": "柴冊儀：擇吉日。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0084",
          "zh": "前期，置柴冊殿及壇。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0085",
          "zh": "壇之制，厚積薪，以木為三級，壇置其上。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0086",
          "zh": "席百尺氈，龍文方茵。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0087",
          "zh": "又置再生母後搜索之室。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0088",
          "zh": "皇帝入再生室，行再生儀畢，八部之叟前導後扈，左右扶翼皇帝冊殿之東北隅。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0089",
          "zh": "拜日畢，乘馬，選外戚之老者禦。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0090",
          "zh": "皇帝疾馳，仆禦者、從者以氈覆之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0091",
          "zh": "皇帝詣高阜地，大臣、諸部帥列儀仗，遙望以拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0092",
          "zh": "皇帝遣使敕曰：「先帝升遐，有伯叔父兄在，當選賢者。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0093",
          "zh": "沖人不德，何以為謀？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0094",
          "zh": "」群臣對曰：」臣等以先帝厚恩，陛下明德，咸願盡心，敢有他圖。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0095",
          "zh": "」皇帝令曰：「必從汝等所願，我將信明賞罰。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0096",
          "zh": "爾有功，陟而任之；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0097",
          "zh": "爾有罪，黜而棄之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0098",
          "zh": "若聽朕命，則當謨之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0099",
          "zh": "」僉曰：「唯帝命是從。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0100",
          "zh": "」皇帝於所識之地，封土石以誌之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0101",
          "zh": "遂行。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0102",
          "zh": "拜先帝御容，宴饗群臣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0103",
          "zh": "翼日，皇帝出冊殿，護衛太保扶翼升壇。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0104",
          "zh": "奉七廟神主置龍文方茵。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0105",
          "zh": "北、南府宰相率群臣圜立，各舉氈邊，贊祝訖，樞密使奉玉寶、玉冊入。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0106",
          "zh": "有司讀冊訖，樞密使稱尊號以進，群臣三稱萬歲，皆拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0107",
          "zh": "宰相、北南院大王、諸部帥進赭、白羊各一群。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0108",
          "zh": "皇帝更衣，拜諸帝御容。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0109",
          "zh": "遂宴群臣，賜賚各有差。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0110",
          "zh": "拜日儀：皇帝升露臺，設褥，向日再拜，上香。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0111",
          "zh": "門使通，閣使或副，應拜臣僚殿左右階陪位，再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0112",
          "zh": "皇帝升坐。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0113",
          "zh": "奏榜訖，北班起居畢，時相已下通名再拜，不出班，奏「聖躬萬福」，又再拜，各祗候。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0114",
          "zh": "宣徽已下橫班同。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0115",
          "zh": "諸司、閣門、北面先奏事；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0116",
          "zh": "餘同。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0117",
          "zh": "教坊與臣僚同。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0118",
          "zh": "告廟儀：至日，臣僚昧爽朝服，詣太祖廟。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0119",
          "zh": "次引臣僚，合班，先見御容，再拜畢，引班首左上，至褥位，再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0120",
          "zh": "贊上香，揖欄內上香畢，復褥位，再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0121",
          "zh": "各祗候立定。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0122",
          "zh": "左右舉告廟祝版，於御容前跪捧。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0123",
          "zh": "中書舍人俯跪，讀訖，俯興，退。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0124",
          "zh": "引班首左下，復位，又再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0125",
          "zh": "分引上殿，次第進酒三。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0126",
          "zh": "分班引出。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0127",
          "zh": "謁廟儀：至日昧爽，南北臣僚各具朝服，赴廟。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0128",
          "zh": "車駕至，臣僚於門外依位序立，望駕鞠躬。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0129",
          "zh": "班首不出班，奏「聖躬萬福」。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0130",
          "zh": "舍人贊各祗候畢，皇帝降車，分引南北臣僚左右入，至丹墀褥位。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0131",
          "zh": "合班定，皇帝升露臺褥位。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0132",
          "zh": "宣徽贊皇帝再拜，殿上下臣僚陪位皆再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0133",
          "zh": "上香畢，退，復位，再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0134",
          "zh": "分引臣僚左右上殿位立，進御容酒依常禮。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0135",
          "zh": "若即退，再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0136",
          "zh": "舍人贊「好去」，引退。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0137",
          "zh": "禮畢。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0138",
          "zh": "告廟、謁廟，皆曰拜容。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0139",
          "zh": "以先帝、先後生辰及忌辰行禮，自太宗始也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0140",
          "zh": "其後正旦、皇帝生辰、諸節辰皆行之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0141",
          "zh": "若忌辰及車駕行幸，亦嘗遣使行禮。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0142",
          "zh": "凡瑟瑟、柴冊、再生、納後則親行之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0143",
          "zh": "凡柴冊、親征則告；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0144",
          "zh": "幸諸京則謁。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0145",
          "zh": "四時有薦新。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0146",
          "zh": "孟冬朔拜陵儀：有司設酒饌於山陵。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0147",
          "zh": "皇帝、皇后駕至，敵烈麻都奏「儀辦」。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0148",
          "zh": "閣門使贊皇帝、皇后詣位四拜訖，巫贊祝燔胙及時服，酹酒薦牲。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0149",
          "zh": "大臣、命婦以次燔胙，四拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0150",
          "zh": "皇帝、皇后率群臣、命婦，循諸陵各三匝。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0151",
          "zh": "還宮。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0152",
          "zh": "翼日，群臣入謝。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0153",
          "zh": "爇節儀：皇帝即位，凡征伐叛國俘掠人民，或臣下進獻人口，或犯罪沒官戶，皇帝親覽閑田，建州縣以居之，設官治其事。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0154",
          "zh": "及帝崩，所置人戶、府庫、錢粟，穹廬中置小氈殿，帝及后妃皆鑄金像納焉。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0155",
          "zh": "節辰、忌日、朔望，皆致祭於穹廬之前。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0156",
          "zh": "又築土為臺，高丈餘，置大盤於上，祭酒食撒於其中，焚之，國俗謂之爇節。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0157",
          "zh": "歲除儀：初夕，敕使及夷離畢率執事郎君至殿前，以鹽及羊膏置爐中燎之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0158",
          "zh": "巫及大巫以次贊祝火神訖，閣門使贊皇帝面火再拜。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0159",
          "zh": "初，皇帝皆親拜，至道宗始命夷離畢拜之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    }
  ]
}