    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0002",
          "zh": "列傳第四",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
