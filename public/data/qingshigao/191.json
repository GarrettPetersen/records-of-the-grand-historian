            }
          ]
        },
        {
          "id": "s0098",
          "zh": "七月甲申解任。乙酉理藩院尚書。八月甲子病免。理藩院尚書。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
