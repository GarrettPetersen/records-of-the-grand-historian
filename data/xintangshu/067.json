    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0006",
          "zh": "719 七年 河西節度增領經略大使。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0007",
          "zh": "升劍南支度、營田、處置、兵馬經略使為節度使，兼昆明軍使，領益、彭、蜀、漢、眉、綿、梓、遂、邛、劍、榮、陵、嘉、普、資、巂、黎、戎、維、茂、簡、龍、雅 、瀘、合二十五州，治益州。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
