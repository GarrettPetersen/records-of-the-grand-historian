    "title": {
      "zh": "卷17 明元六王",
      "en": "Volume 17: Emperor Mingyuan's Six Princes",
      "raw": "卷17 明元六王 Volume 17: Emperor Mingyuan's Six Princes"
    },
    "sentenceCount": 44,
    "translatedCount": 0,
    "glossarySize": 38401,
    "scrapedAt": "2026-04-25T21:48:12.165Z",
