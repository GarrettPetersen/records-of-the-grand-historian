      "sentences": [
        {
          "id": "s0135",
          "zh": "評曰：魏后妃之家，雖云富貴，未有若衰漢乘非其據，宰割朝政者也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0136",
          "zh": "鑑往易軌，於斯為美。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0137",
          "zh": "追觀陳群之議，棧潛之論，適足以為百王之規典，垂憲範乎後葉矣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
