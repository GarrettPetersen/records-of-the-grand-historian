    "title": {
      "zh": "卷五十二 列傳第四十六 止足",
      "en": "Volume 52: The Self-Sufficient",
      "raw": "卷五十二 列傳第四十六 止足 Volume 52: The Self-Sufficient"
    },
    "sentenceCount": 156,
    "translatedCount": 0,
    "glossarySize": 37531,
    "scrapedAt": "2026-04-25T21:37:00.758Z",
