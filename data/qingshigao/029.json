      "sentences": [
        {
          "id": "s0001",
          "zh": "康熙壬子年恒星黃道經緯度表一 揆日所以正時，候星所以紀日。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0002",
          "zh": "日行黃道，故推測恒星，必求黃道經緯度分。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0003",
          "zh": "且恒星循黃道東行，上考下求，每年祗加減經度五十一秒。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0004",
          "zh": "今依康熙壬子舊測恒星黃道經緯度分，及南北之向，大小之等，為二卷。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0005",
          "zh": "先列降婁戌宮至鶉尾巳宮，凡一百八十度之名星及附近星，如左：",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
