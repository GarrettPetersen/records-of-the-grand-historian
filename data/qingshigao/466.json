    "citation": null
  },
  "content": [
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0001",
          "zh": "徐用儀 徐用儀，字筱雲，浙江海鹽人。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0002",
          "zh": "由副貢生入貲為主事，官刑部。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0003",
          "zh": "咸豐九年，舉順天鄉試．同治初，充軍機章京，兼直總理各國事務衙門。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0004",
          "zh": "累遷鴻臚寺少卿，以憂歸。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0005",
          "zh": "光緒三年，起太僕寺少卿，遷大理寺卿，直軍機如故。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0006",
          "zh": "擢工部侍郎，始罷直。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0007",
          "zh": "旋充總理衙門大臣，歷兵部、吏部侍郎，授軍機大臣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0008",
          "zh": "二十年，加太子少保。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0009",
          "zh": "日朝搆为，舉朝爭議和戰，樞臣孫毓汶被劾罷，翁同龢繼入，主戰益力。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0010",
          "zh": "用儀論事與同龢忤，遂出樞廷，並解總署事。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0011",
          "zh": "二十四年，皇太后再訓政，復直總署，迺密薦太常寺卿袁昶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0012",
          "zh": "會許景澄奉使還，被命同入署。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0013",
          "zh": "二十六年，拳禍起。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0014",
          "zh": "先是上以行新政為中外所推，而儲嗣久虛。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0015",
          "zh": "載漪既用事，陰謀廢立，慮外人為梗，聞拳民有神勇，仇西教，欲倚以集事，召入京，遂縱恣不可制。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0016",
          "zh": "用儀請嚴禁遏，不聽。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0017",
          "zh": "俄戕德使克林德，用儀駭曰：「禍始此矣！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0018",
          "zh": "」言於慶親王奕劻，厚歛之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0019",
          "zh": "各國兵艦至津沽，詔廷臣集議和戰。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0020",
          "zh": "用儀、景澄、昶及尚書立山、內閣學士聯元並言：「奸民不可縱，外为不可啟。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0021",
          "zh": "」而載漪等主戰甚力，在廷大臣率依違不決。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0022",
          "zh": "用儀以太后命詣使館議緩兵，當事者益目為奸邪。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0023",
          "zh": "景澄、昶先被害，用儀知不免，意氣自如。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0024",
          "zh": "七月既望，遽發拳匪捕之於家，擁至莊王邸。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0025",
          "zh": "用儀不置辯，第曰：「天降奇禍，死固分耳！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0026",
          "zh": "」遂與立山、聯元同棄市。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0027",
          "zh": "越三日，聯軍入京，而兩宮西狩。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0028",
          "zh": "十二月，詔湔雪，復故官。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0029",
          "zh": "宣統元年，追諡忠愍。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0030",
          "zh": "浙人祠之西湖，與景澄、昶並稱「三忠」。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0031",
          "zh": "許景澄 許景澄，字竹篔，嘉興人。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0032",
          "zh": "同治七年進士，選庶吉士，授編修。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0033",
          "zh": "明習時事，大學士文祥以使才薦。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0034",
          "zh": "光緒六年，詔使日本，遭父憂，未行。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0035",
          "zh": "服闋，補侍講。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0036",
          "zh": "法越之役，條上籌備事宜，上褒納。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0037",
          "zh": "十年，出使法德意和奧五國大臣，兼攝比國使務。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0038",
          "zh": "時海軍初創，從德國購造鐵艦，未就。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0039",
          "zh": "景澄躬歷船廠，鉤稽輯上外國師船表。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0040",
          "zh": "又言海軍宜定屯埠膠州灣，設鐵甲尓船大沽口。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0041",
          "zh": "轉侍讀，母憂歸。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0042",
          "zh": "十六年，充出使俄德奧和四國大臣，累遷至內閣學士。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0043",
          "zh": "先是俄兵游獵，常越界，侵及帕米爾地，景澄爭之，俄援舊議定界起烏什別里山，自此而南屬中國，其西南屬俄。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0044",
          "zh": "俄人則欲以薩雷闊勒為界。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0045",
          "zh": "相持三載，俄始允改議，其帕界未定以前，各不進兵，以保和好。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0046",
          "zh": "因著帕米爾圖說、西北邊界地名考證，為他日界約備。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0047",
          "zh": "擢工部侍郎。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0048",
          "zh": "是時俄、德迫日人還遼東，景澄曰：「俄謀自便，德圖償報，事故從此多矣！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0049",
          "zh": "」疏請分遣兩使，從之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0050",
          "zh": "二十三年，調充德國使臣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0051",
          "zh": "會俄建西比利亞鐵道，謀自黑龍江達海參崴，朝議拒之，迺更名商辦，許中國投貲五百萬，所謂東清鐵路公司也。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0052",
          "zh": "詔景澄綜其事，力阻路悋南溢，稽察運船毋漏稅。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0053",
          "zh": "已而俄人索租旅順，充頭等公使，會駐俄使臣楊儒定議俄都。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0054",
          "zh": "事竣，移疾歸，召授總理各國事務大臣兼禮部侍郎。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0055",
          "zh": "調吏部，充大學堂總教習、管學大臣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0056",
          "zh": "意大利索我三門灣，景澄抗言爭之，事迺寢。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0057",
          "zh": "未幾，拳禍作，景澄召見時，歷陳兵为不可啟，春秋之義，不殺行人，圍攻使館，實背公法。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0058",
          "zh": "太后聞之動容，而載漪等斥為邪說。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0059",
          "zh": "聯軍偪近畿，景澄等遂坐主和棄市。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0060",
          "zh": "宣統元年，追諡文肅。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0061",
          "zh": "袁昶 袁昶，字爽秋，桐廬人。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0062",
          "zh": "從劉熙載讀，博通掌故。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0063",
          "zh": "光緒二年進士，授戶部主事，充總理各國事務衙門章京。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0064",
          "zh": "十八年，以員外郎出任徽寧池太廣道。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0065",
          "zh": "誡僚屬，抑胥吏，多所興革；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0066",
          "zh": "擴中江書院齋舍，課以實學；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0067",
          "zh": "建尊經閣，購書數萬卷；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0068",
          "zh": "汰常關耗費歲萬八千金，悉還諸公；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0069",
          "zh": "定專條，納新關穀米出口稅，歲羨數十萬；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0070",
          "zh": "督修蕪湖西南濱江圩隄，自大關亭至魯港，延袤十二里；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0071",
          "zh": "更穿築新縷隄三百七十丈，自是蓄洩有資，田廬完固，民歌誦之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0072",
          "zh": "膠州事起，下詔求言，昶條列時政二萬餘言，以：「德突據膠灣，其禍急而小；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0073",
          "zh": "俄自西北至東北，與我壤地相錯，蒙喀四十八部將折入異域，其禍紆而大。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0074",
          "zh": "宜及今預練勁旅，痛革吉、奉華靡風習。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0075",
          "zh": "自頃兵力不能議戰，要不可不議守。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0076",
          "zh": "我朝八旗初制，文武不分途，京外不分途，人皆兵，官皆將，故人才盛，國勢強。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0077",
          "zh": "承平日久，文法繁密，諸臣救過之不暇，於是相率為鄉愿，而舉國之人才靡矣！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0078",
          "zh": "金田洪、楊之亂，其始一小民耳，猶窮全國之力僅而克之，況諸國互肆蠶食之心，有不乘吾敝而攻吾之短者哉？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0079",
          "zh": "夫敵國外患，為殷憂啟聖之資。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0080",
          "zh": "苟得其人，毋拘以文法，則理財、練兵、防海、交鄰之策，可次第就理。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0081",
          "zh": "」上親書其綱要於冊，下中外大臣議行。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0082",
          "zh": "二十四年，遷陝西按察使，未到官，擢江寧布政使，調直隸。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0083",
          "zh": "未幾，內召，以三品京堂在總理衙門行走，授光祿寺卿，轉太常寺卿。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0084",
          "zh": "時財用匱，議整釐稅。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0085",
          "zh": "昶極言釐金名病商，實病民，不可議增。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0086",
          "zh": "義和團起山東，屠戮外國教士。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0087",
          "zh": "昶與許景澄相善，廷詢時，陳奏皆谒慨，上執景澄手而泣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0088",
          "zh": "昶連上二疏，力言奸民不可縱，使臣不宜殺，皆不報。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0089",
          "zh": "復與景澄合上第三疏，嚴劾釀亂大臣，未及奏，已被禍，疏稿為世稱誦。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0090",
          "zh": "追諡忠節，江南人祠之蕪湖。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0091",
          "zh": "昶嘗慨士鮮實學，輯農桑、兵、醫、輿地、治術、掌故諸書，為漸西村叢刻。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0092",
          "zh": "立山 立山，字豫甫，土默特氏，蒙古正黃旗人。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0093",
          "zh": "光緒五年，以員外郎出監蘇州織造，歷四任迺得代。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0094",
          "zh": "論修南苑工，賜二品服。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0095",
          "zh": "累遷奉宸苑卿、總管內務府大臣、正白旗漢軍副都統、戶部侍郎。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0096",
          "zh": "二十年，加太子少保。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0097",
          "zh": "盜竊寧壽宮物，坐失察，鐫職留任。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0098",
          "zh": "二十六年，擢戶部尚書。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0099",
          "zh": "立山久典內廷，同列嫉其寵眷。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0100",
          "zh": "會拳禍起，聯軍至天津，廷臣集議御前。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0101",
          "zh": "載漪盛推拳民可用，立山適在側，太后謂：「汝言如何？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0102",
          "zh": "」立山曰：「拳民雖無他，然其術多不驗．」載漪怒曰：「用其心耳，奚問術？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0103",
          "zh": "立山必與外人通，請以立山退外兵！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0104",
          "zh": "」立山曰：「首言戰者載漪也！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0105",
          "zh": "臣主和，又不諳外事，不足任。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0106",
          "zh": "」載漪益仇之，因其宅讫教堂，迺中以蜚語，謂藏匿外人，竟論死。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0107",
          "zh": "宣統元年，追諡忠貞。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0108",
          "zh": "聯元 聯元，字仙蘅，崔佳氏，滿洲鑲紅旗人。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0109",
          "zh": "同治七年進士，選庶吉士，授檢討，累遷侍講。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0110",
          "zh": "大考，左遷中允，再陟侍講。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0111",
          "zh": "以京察，出知安徽太平府，調安慶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0112",
          "zh": "兩薦卓異，署滁和道，遷廣東惠潮嘉道。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0113",
          "zh": "汕頭者，通商要衢也，奸人倚英領事為民暴，聯元裁以法，良善獲安。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0114",
          "zh": "二十四年，擢安徽按察使，入覲，改三品京堂，在總理衙門行走。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0115",
          "zh": "又明年，補內閣學士。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0116",
          "zh": "拳民仇西教，載漪、剛毅助之，勢益橫，日夜圍攻使館，不能下。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0117",
          "zh": "大臣負清望者徐桐、崇綺，皆謂：「民氣可用。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0118",
          "zh": "」聯元與崇綺爭論帝前，謂：「民氣可用，匪氣不可用。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0119",
          "zh": "」聯軍既陷大沽，載漪等猶壹意主戰。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0120",
          "zh": "聯元謂：「甲午之役，一日本且不能勝，況八強國乎？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0121",
          "zh": "儻戰而敗，如宗廟何？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0122",
          "zh": "」載漪斥其言不祥，七月十七日，斬西市。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0123",
          "zh": "昭雪後，予諡文直。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0124",
          "zh": "順天府奏請立山、聯元合祠宣武門外，而聯元祖居寶坻，更於其地建專祠焉。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0125",
          "zh": "論曰 論曰：清代優禮廷臣，罕有誅罰。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0126",
          "zh": "拳禍既起，忠諫大臣駢首就戮，豈獨非帝意哉？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0127",
          "zh": "觀用儀諸人所論事勢利害，昭昭如此，迺終不能回當軸之聽，何其昧焉？",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0128",
          "zh": "世傳大節，並號「五忠」，不數日而遂昭雪，允哉！",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0129",
          "zh": "傳253",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    }
  ]
}