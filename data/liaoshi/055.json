          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0114",
          "zh": "四望車，吊臨用之。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0115",
          "zh": "金飾，紫油纁通幰。",
          "translations": [
            {
