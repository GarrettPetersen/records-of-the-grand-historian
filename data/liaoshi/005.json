    "title": {
      "zh": "卷五 本紀第五: 世宗",
      "en": "Volume 5 Annals 5: Shizong",
      "raw": "卷五 本紀第五: 世宗 Volume 5 Annals 5: Shizong"
    },
    "sentenceCount": 36,
    "translatedCount": 0,
    "glossarySize": 51262,
    "scrapedAt": "2026-04-25T23:49:08.463Z",
