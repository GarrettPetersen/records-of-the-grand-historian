  "content": [
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0001",
          "zh": "進《宋史》表",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0002",
          "zh": "開府儀同三司、上柱國、錄軍國重事、中書右丞相、監修國史、領經筵事、提調宣政院太醫院廣惠司事 臣阿魯圖 等言：",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0003",
          "zh": "竊惟周公念先業之艱難，《七月》之詩是作；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0004",
          "zh": "孔子論前王之文獻，二代之禮可言。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0005",
          "zh": "故觀趙氏隆替之由，足見皇元混一之績。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0006",
          "zh": "欽惟世祖聖德神功文武皇帝，初由宗邸親總大軍，龍旂出指於離方，羽葆歸登於乾御，櫛風沐雨，詎辭跋履之勞；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0007",
          "zh": "略地攻城，咸遵禀授之算。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0008",
          "zh": "揚舲而平江、漢，卷甲而克襄、樊。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0009",
          "zh": "龔行吊伐之師，昭受寵綏之寄。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0010",
          "zh": "及夫收圖書於勝國，輯黼冔於神京，拔宋臣而列政塗，載《宋史》而歸秘府。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0011",
          "zh": "然後告成郊廟，錫慶臣民，推大賚以惟均，示一統之無外。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0012",
          "zh": "樞庭偃武，既編戡定之勳；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0013",
          "zh": "翰苑摛文，尋奉纂修之旨。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0014",
          "zh": "事幾有待，歲月易遷。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0015",
          "zh": "累朝每切於繼承，多務未遑於制作。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0016",
          "zh": "臣阿魯圖等，誠惶誠恐，頓首頓首，欽惟皇帝陛下恢弘至道，紹述丕謨。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0017",
          "zh": "往行前言，樂討論於古訓；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0018",
          "zh": "祖宗功德，思揚厲於耿光。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0019",
          "zh": "惟我朝大啟基圖，彼吳會後歸版籍。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0020",
          "zh": "視金源其未遠，紬石室以具存，及茲累洽之時，成此彌文之典。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0021",
          "zh": "命臣阿魯圖、左丞相臣別兒怯不花領史事，前右丞相臣脫脫為都總裁，平章政事臣帖穆爾達世、御史大夫臣惟一、翰林學士承旨臣起巖、臣玄、治書御史臣好文、禮部尚書臣沂、崇文大監臣宗瑞為總裁官，平章政事臣納麟、臣顏、前中書右丞 臣達世睦邇、左丞 臣守簡、參議 臣岳柱、臣住、臣思謙、郎中 臣斡欒、臣思立等協恭董治，史官工部侍郎 臣斡玉倫徒，秘書卿 臣泰不華、太常僉院 臣杜秉彝、翰林直學士 臣宋褧，國子司業 臣王思誠、臣澤民、集賢待制 臣干文傳、翰林待制 臣張瑾、臣師道、宣文閣鑒書博士 臣麥文貴、監察御史 臣余闕、太常博士 臣李齊、翰林修撰 臣劉聞、太醫院都事 臣賈魯、國子助教 臣馮福可、太廟署令 臣陳祖仁、西臺御史 臣趙中、翰林應奉 臣王儀、臣貞、秘書著作左郎 臣譚慥、翰林編修 臣張翥、國子助教 臣吳當、經筵檢討 臣危素編劘分局，彙粹為書。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0022",
          "zh": "起自東都，迄於南渡，紀載餘三百載，始終纔一再期。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0023",
          "zh": "考夫建隆、淳化之經營，景德、咸淳之潤色，慶曆、皇祐以忠厚美風化，元豐、熙寧以聰明紊憲章。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0024",
          "zh": "馴致紹聖紛紜，崇寧荒亂，治忽昭陳於方冊，操存實本於宮庭。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0025",
          "zh": "若乃建炎、紹興之圖回，乾道、淳熙之保乂，正直用則人存政舉，邪佞進則臣辱主憂。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0026",
          "zh": "光、寧之朝，僅守宗社，理、度之世，日蹙封疆，顧乃拘信使以渝盟，納畔臣而侵境，由權奸之擅命，啟事釁以召兵。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0027",
          "zh": "厥後瀛國歸朝，吉王航海，齊亡而訪王燭，乃存秉節之臣；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0028",
          "zh": "楚滅而諭魯公，堪矜守禮之國。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0029",
          "zh": "載惟貞元之會合，屬當泰道之熙明。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0030",
          "zh": "眾言淆亂於當時，大義昭宣於今日。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0031",
          "zh": "矧先儒性命之說，資聖代表章之功，先理致而後文辭，崇道德而黜功利，書法以之而矜式，彝倫賴是而匡扶。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0032",
          "zh": "雖微董孤直筆之可稱，庶逃司馬寡識而輕信。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0033",
          "zh": "至若論其有弊，亦惟斷以至公。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0034",
          "zh": "大概聲容盛而實德衰，論建多而成效少。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0035",
          "zh": "且辭之繁簡以事，而文之古今以時，舊史之傳述既多，雜記之蒐羅又廣。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0036",
          "zh": "於是參是非而去取，權豐約以損增。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0037",
          "zh": "事嚴敢計於疾徐，日積亦虞於玩愒。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "sentences": [
        {
          "id": "s0038",
          "zh": "臣阿魯圖 等忝司當揆，實預提綱，周詢在局之言，靡不究心乃職。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0039",
          "zh": "第述作之才有限，而報效之志無窮。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0040",
          "zh": "儻垂清燕之觀，尚助緝熙之益。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0041",
          "zh": "曰若帝堯，曰若帝舜，惟聖心稽古之功；",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0042",
          "zh": "監於有夏，監于有殷，乃臣子告君之道。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        },
        {
          "id": "s0043",
          "zh": "謹撰述《本紀》四十七卷，《志》一百六十二卷，《表》三十二卷，《列傳》、《世家》二百二十五卷，裝潢成四百九十二帙，隨表塵獻以聞。",
          "translations": [
            {
              "lang": "en",
              "literal": "",
              "idiomatic": "",
              "translator": ""
            }
          ]
        }
      ],
      "translations": [
        {
          "lang": "en",
          "literal": "",
          "idiomatic": "",
          "translator": ""
        }
      ]
    }
  ]
}