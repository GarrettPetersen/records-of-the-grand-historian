      "zh": "卷5 帝紀第5 恭帝",
      "en": "Volume 5 Annals 5: Emperor Gong",
      "raw": "卷5 帝紀第5 恭帝 Volume 5 Annals 5: Emperor Gong"
    },
    "sentenceCount": 71,
    "translatedCount": 0,
    "glossarySize": 40479,
